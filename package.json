{
  "name": "chdb",
  "version": "3.1.0",
  "description": "chDB bindings for nodejs",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "chdb-gen-types": "dist/layer3/codegen/cli.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./connection": {
      "types": "./dist/connection/index.d.ts",
      "require": "./dist/connection/index.js",
      "default": "./dist/connection/index.js"
    },
    "./ai-sdk": {
      "types": "./integrations/ai-sdk.d.mts",
      "import": "./integrations/ai-sdk.mjs"
    },
    "./mastra": {
      "types": "./integrations/mastra.d.mts",
      "import": "./integrations/mastra.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chdb-io/chdb-node.git"
  },
  "scripts": {
    "test": "mocha test_basic.js test_connection.js --timeout 15000",
    "test:v3": "vitest run",
    "test:all": "npm run test && npm run test:v3",
    "typecheck": "tsc -p tsconfig.json",
    "libchdb": "bash ./update_libchdb.sh",
    "fixloaderpath": "bash ./fix_loader_path.sh",
    "build:platform": "bash ./scripts/build-platform-pkg.sh",
    "bench": "node bench/bench.js",
    "build": "node-gyp configure build --verbose && npm run fixloaderpath && npm run build:ts",
    "build:ts": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run build:ts",
    "install": "node -e \"\""
  },
  "author": {
    "name": "chdb",
    "email": "auxten@clickhouse.com"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "dist",
    "example.js",
    "AGENTS.md",
    "llms-full.txt",
    "src/layer3/AGENTS.md",
    "src/connection/AGENTS.md",
    "integrations"
  ],
  "devDependencies": {
    "@mastra/core": "^1.47.0",
    "@types/node": "^20.14.0",
    "ai": "^7.0.2",
    "apache-arrow": "^21.1.0",
    "chai": "^4.5.0",
    "mocha": "^10.7.3",
    "node-gyp": "^9.3.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@clickhouse/client-common": "^1.22.0",
    "node-addon-api": "^6.1.0",
    "node-gyp-build": "^4.6.0"
  },
  "optionalDependencies": {
    "@chdb/lib-darwin-arm64": "26.5.2",
    "@chdb/lib-darwin-x64": "26.5.2",
    "@chdb/lib-linux-arm64-gnu": "26.5.2",
    "@chdb/lib-linux-x64-gnu": "26.5.2"
  },
  "peerDependencies": {
    "@mastra/core": ">=0.10",
    "ai": ">=5",
    "apache-arrow": ">=14",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "apache-arrow": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "@mastra/core": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "keywords": [
    "chdb",
    "chdb.io",
    "chdb-node",
    "chdb bindings",
    "chdb nodejs",
    "chdb node",
    "chdb bindings nodejs",
    "chdb bindings node",
    "ClickHouse",
    "Embedded Database"
  ]
}
